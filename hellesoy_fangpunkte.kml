<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Fangpunkte Hellesøy – Testdaten</name>
    <description>Beispiel-Fangpunkte rund um Hellesøy und Fedje</description>

    <Placemark>
      <name>Hellesøy Leuchtturm – Dorsch</name>
      <description>Guter Platz für Dorsch und Sei. Tiefe ca. 18m. Beste Zeit: Ebbe.</description>
      <Point><coordinates>4.7420,60.7850,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Fedje Nordspitze – Köhler</name>
      <description>Köhler und Makrele im Sommer. Starke Strömung bei Tidenwechsel.</description>
      <Point><coordinates>4.7280,60.7920,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Fedje Westseite – Lachsplatz</name>
      <description>Lachs auf dem Weg durch den Fjord. Spinner und Blinker.</description>
      <Point><coordinates>4.7150,60.7780,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Felsformation Sør – Meerforelle</name>
      <description>Meerforelle beim Waten. Morgens am besten. Kleine Streamers.</description>
      <Point><coordinates>4.7500,60.7720,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Tiefe Rinne – Leng und Lumb</name>
      <description>Tiefe ca. 60m. Leng, Lumb, großer Dorsch. Pilker 200–300g.</description>
      <Point><coordinates>4.7600,60.7900,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Fedje Hafen – Kleinangler</name>
      <description>Vom Steg. Makrele, Hering, Kleifisch. Gut für Kinder.</description>
      <Point><coordinates>4.7340,60.7840,0</coordinates></Point>
    </Placemark>

  </Document>
</kml>
